{
  "name": "Email Writer Assistant",
  "description": "AI-powered Email Reply Generator",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "*://mail.google.com/*"
  ],
"content_scripts": [
  {
    "matches": [
      "*://mail.google.com/*"
    ],
    "js": [
      "gmail.js",
      "api.js",
      "popup.js",
      "content.js"
    ],
    "css": [
      "content.css",
      "popup.css"
    ],
    "run_at": "document_idle"
  }
],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "*://mail.google.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Email Writer Assistant"
  }
}